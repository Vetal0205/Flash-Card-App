{
    "name": "minddeck-api",
    "version": "0.1.0",
    "description": "MindDeck backend API — flashcard study application",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "start": "node .",
        "start-watch": "nodemon --delay 2000ms --exec npm run start",
